# Database (required)
# Local SQLite: file:./dev.db
# Vercel: use Neon, Vercel Postgres, or Turso (see DEPLOYMENT.md)
DATABASE_URL="file:./dev.db"

# NextAuth (required for admin login)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-random-string-32-chars-min"

# Optional: public site URL (for API calls, emails, etc.)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
