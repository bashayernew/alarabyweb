# ===========================================
# REQUIRED FOR VERCEL PRODUCTION
# ===========================================

# Database (required) - PostgreSQL connection string
# Local: use Neon free tier or local Postgres
# Vercel: same connection string in project env vars
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/postgres?sslmode=require"

# NextAuth (required for admin login)
# Production: use your Vercel URL, e.g. https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-random-string-32-chars-min"

# ===========================================
# OPTIONAL
# ===========================================

# Public site URL (used for server-side fetch in products/[slug])
# Vercel sets VERCEL_URL automatically; override with this if needed
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Seed script only (optional - defaults: admin123@gmail.com / admin123)
# ADMIN_EMAIL="admin123@gmail.com"
# ADMIN_PASSWORD="admin123"
